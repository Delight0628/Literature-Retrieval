# Dify 配置（可选）
DIFY_API_URL=http://localhost/v1
DIFY_API_KEY=your-dify-api-key-here

# 或者使用 Dify 云服务
# DIFY_API_URL=https://api.dify.ai/v1
# DIFY_API_KEY=your-dify-api-key-here
# DIFY_DATASET_ID=your-dataset-id-here

# Railway 部署说明：
# 1. 将上述变量添加到 Railway Dashboard 的 Variables 标签页
# 2. Railway 会自动设置 PORT 环境变量，无需手动配置
# 3. 数据持久化需要在 Railway Settings → Volumes 中配置
